/* ===== 三、底栏终端重构 (战术闭环) ===== */
#send_form {
  /* 使用极深的暗夜蓝黑，与上方背景拉开微妙层次 */
  background-color: rgba(8, 12, 16, 0.95) !important; 
  backdrop-filter: blur(10px) !important;
  border: none !important;
  /* 顶部增加一道极细的夜翼蓝战术轮廓线 */
  border-top: 1px solid rgba(98, 159, 255, 0.15) !important;
  border-radius: 0 !important;
  padding: 4px 10px;
  /* 增加向上的微弱暗影，让输入框像一个悬浮的操作台 */
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.6) !important; 
  min-height: auto !important;
  z-index: 100 !important;
}

#send_textarea {
  background-color: transparent !important;
  border: none !important;
  /* 常态下输入框底线为暗虚线 */
  border-bottom: 1px dashed rgba(115, 140, 170, 0.3) !important; 
  border-radius: 0 !important;
  font-family: var(--font-main);
  color: var(--ink-main) !important;
  text-shadow: none !important; /* 保证输入文本绝对锐利 */
  padding: 10px 5px 10px 15px;
  box-shadow: none !important;
  min-height: 40px !important;
  clip-path: none !important;
  transition: border-color 0.4s ease, background-color 0.4s ease;
}

/* 交互反馈：激活输入框时的战术高亮 */
#send_textarea:focus {
  /* 聚焦时底线变为夜翼蓝实线，并带有极其微弱的背景提亮 */
  border-bottom: 1px solid rgba(98, 159, 255, 0.6) !important;
  background-color: rgba(98, 159, 255, 0.02) !important;
  outline: none !important;
}

/* 底栏图标 */
#send_form [class*="fa-"]::before {
  color: var(--ink-sub) !important;
  font-size: 14px !important;
  text-shadow: var(--glow-light);
  transition: color 0.8s ease, text-shadow 0.8s ease;
}
@media (hover: hover) {
  #send_form [class*="fa-"]:hover::before {
    color: var(--ink-accent) !important;
    text-shadow: var(--glow-strong);
  }
}

/* ==================================================== */
/* 发送按钮重构：夜翼 Logo 战术版 */
/* ==================================================== */

/* 1. 彻底隐藏原生图标与子元素 */
#send_button *, #send_but *, #send-button *,
#send_button::before, #send_button::after,
#send_but::before, #send_but::after {
  display: none !important;
  content: none !important;
  opacity: 0 !important;
}

/* 2. Logo 渲染与常态设定 */
#send_button, #send_but, #send-button {
  background-color: transparent !important;
  background-image: url('https://github.com/nw37/ST_Assets/blob/main/icons/icon12.png?raw=true') !important;
  
  /* 【核心修正 1：解除压缩】使用 contain 确保长宽比不畸形，居中显示 */
  background-size: contain !important; 
  background-repeat: no-repeat !important;
  background-position: center !important;
  
  border: none !important;
  width: 45px !important;
  height: 45px !important;
  
  /* 【核心修正 2：锁定可见度】强制覆盖ST“输入框为空时发暗”的系统设定 */
  opacity: 0.85 !important; 
  
  /* 赋予专属的战术蓝微光，不再使用全局弱阴影 */
  filter: drop-shadow(0 0 4px rgba(98, 159, 255, 0.6)) !important;
  transition: all 0.3s ease-in-out !important;
  cursor: pointer !important;
  position: relative !important;
}

/* 3. 交互反馈：悬停时的高亮与动态 */
#send_button:hover, #send_but:hover, #send-button:hover {
  opacity: 1 !important; /* 悬停时透明度拉满，呈现最纯正的Logo蓝 */
  
  /* 增强发光，略微提亮，并保留你设计的倾斜动作 */
  filter: drop-shadow(0 0 12px rgba(98, 159, 255, 0.9)) brightness(1.15) !important;
  transform: scale(1.1) rotate(-5deg) !important;
}

/* 4. 点击反馈：缩放 */
#send_button:active, #send_but:active, #send-button:active {
  transform: scale(0.9) !important;
}

