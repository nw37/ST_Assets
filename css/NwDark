}

/* ===== 设置面板 h4 与 standoutHeader 统一样式 (暗色系) ===== */
#user-settings-block h4,
.user-settings h4,
.settings-section h4,
h4.standoutHeader,
div.standoutHeader,
div.inline-drawer-header,
#extensions_settings h4,
#prompt-manager h4 {
