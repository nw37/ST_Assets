/* ==================================================== */
/* 🌧️ 修复版：霓虹幽蓝夜雨动画 */
/* ==================================================== */

/* ==================================================== */
/* 强制接管系统背景 (修复被 ST 原生背景遮挡的问题) */
/* ==================================================== */

/* 1. 强制清空父级图层的干扰 */
#bg_layer {
    background-image: none !important;
    background-color: #000 !important; /* 拉伸时如果出现黑边，使用纯黑垫底 */
}

/* 2. 直接对 ST 的核心背景双图层进行覆盖 */
#bg1, #bg2 {
    /* 替换为 GitHub Raw 专用直链，降低加载失败率 */
    background-image: url('https://raw.githubusercontent.com/nw37/ST_Assets/main/pic/bg.jpg') !important;
    
    /* 强制铺满屏幕，不留黑边 */
    background-size: cover !important; 
    background-repeat: no-repeat !important; 
    
    /* 根据原画，夜翼位于画面偏右侧，我们将锚点定在右侧，确保人物不被裁掉 */
    background-position: 80% 50% !important;
    
    /* 继承你之前的光影克制逻辑，压暗背景，凸显文字和霓虹雨丝 */
    filter: brightness(0.85) !important;
}

/* 第一层：远景细小雨丝 */
html::after {
  content: '';
  position: fixed;
  top: -100vh;
  left: 0;
  /* 恢复宽度，黑底上太细会隐形 */
  width: 1.5px; 
  height: 25px;
  /* 提高亮度和基础不透明度，使用更亮的冰蓝色 */
  background: rgba(138, 180, 248, 0.35); 
  z-index: 9998 !important;
  pointer-events: none !important;
  filter: blur(0.8px);
  /* 大幅提升阴影（其他雨滴）的可见度 */
  box-shadow:
    8vw 15vh 0 rgba(138, 180, 248, 0.25),
    22vw 75vh 0 rgba(138, 180, 248, 0.3),
    38vw 8vh 0 rgba(138, 180, 248, 0.15),
    52vw 85vh 0 rgba(138, 180, 248, 0.25),
    68vw 25vh 0 rgba(138, 180, 248, 0.2),
    84vw 140vh 0 rgba(138, 180, 248, 0.15),
    12vw 110vh 0 rgba(138, 180, 248, 0.3),
    33vw 170vh 0 rgba(138, 180, 248, 0.15),
    57vw 55vh 0 rgba(138, 180, 248, 0.1),
    76vw 95vh 0 rgba(138, 180, 248, 0.25),
    94vw 35vh 0 rgba(138, 180, 248, 0.35);
  animation: rain-distant 3s linear infinite;
}

@keyframes rain-distant {
  0%   { transform: translateY(0); opacity: 0; }
  15%  { opacity: 0.85; } /* 动画显影更清晰 */
  85%  { opacity: 0.85; }
  100% { transform: translateY(220vh); opacity: 0; }
}

/* 第二层：近景清晰雨丝 */
body::after {
  content: '';
  position: fixed;
  top: -100vh;
  left: 0;
  /* 增加宽度，模拟近景大雨滴 */
  width: 2px; 
  height: 35px;
  /* 核心雨滴更亮，带有荧光感 */
  background: rgba(158, 194, 255, 0.6); 
  z-index: 9999 !important;
  pointer-events: none !important;
  filter: blur(0.4px);
  box-shadow:
    10vw 20vh 0 rgba(158, 194, 255, 0.35),
    25vw 80vh 0 rgba(158, 194, 255, 0.45),
    40vw 10vh 0 rgba(158, 194, 255, 0.25),
    55vw 90vh 0 rgba(158, 194, 255, 0.4),
    70vw 30vh 0 rgba(158, 194, 255, 0.35),
    85vw 150vh 0 rgba(158, 194, 255, 0.25),
    15vw 120vh 0 rgba(158, 194, 255, 0.4),
    35vw 180vh 0 rgba(158, 194, 255, 0.25),
    60vw 60vh 0 rgba(158, 194, 255, 0.15),
    80vw 100vh 0 rgba(158, 194, 255, 0.35),
    95vw 40vh 0 rgba(158, 194, 255, 0.5);
  animation: rain-near 2.2s linear infinite;
}

@keyframes rain-near {
  0%   { transform: translateY(0); opacity: 0; }
  10%  { opacity: 1; }
  85%  { opacity: 1; }
  100% { transform: translateY(220vh); opacity: 0; }
}

