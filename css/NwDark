  border-bottom: 1px solid var(--book-border) !important;
  margin-bottom: 6px;
  padding: 8px 12px !important;
  border-radius: 4px 4px 0 0;
  font-weight: normal;
  text-shadow: var(--glow-light);
}
#user-settings-block h4:hover,
.user-settings h4:hover,
.settings-section h4:hover,
h4.standoutHeader:hover,
div.standoutHeader:hover,
div.inline-drawer-header:hover,
#extensions_settings h4:hover,
#prompt-manager h4:hover {
  background: rgba(98, 159, 255, 0.25) !important;
}

/* ===== 提示词管理器开关颜色 ===== */
#completion_prompt_manager_list .fa-toggle-on::before {
  color: var(--ink-accent) !important;
}
#completion_prompt_manager_list .fa-toggle-off::before {
  color: rgba(98, 159, 255, 0.3) !important;
}

/* ===== 心理描写：反引号 → <code> ===== */
.mes_text code {
  background-color: rgba(25, 35, 45, 0.5) !important; /* 加深底色 */
  color: #7A9CB8 !important; /* 降低文字亮度 */
  font-family: var(--font-main);
  font-style: normal;
  font-size: 1em;
  padding: 2px 6px;
  border-radius: 4px;
  border: none;
  text-shadow: none !important;
}

/* ==================================================== */
/* 📱 移动端专属适配与降级 (最大宽度 768px 触发) */
/* ==================================================== */
@media (max-width: 768px) {
  
  /* 1. 背景重置：手机竖屏太窄，必须拉回居中，保证人物可见 */

  /* 2. 交互降级：取消悬停阅读机制。思维链在手机上强制常亮、不模糊 */
  .mes[is_user="false"] .mes_reasoning_header_title::before {
    animation: none !important;
    opacity: 1 !important;
    filter: blur(0px) !important;
    text-shadow: var(--glow-strong) !important;
  }

  /* 3. 空间优化：缩小大标题和水印，防止在小屏幕上挤占过多正文空间 */
  .mes::after { font-size: 3.5em !important; } /* 后景英文缩小 */
  .mes::before { font-size: 1.2em !important; top: 45px !important; } /* 前景中文缩小 */
  .mes { padding-top: 90px !important; } /* 缩小头部留白 */

  /* 4. 性能保护：如果在手机上打字卡顿，请删掉这部分的注释内容，留下红色感叹号以内的代码就够了，这行代码将关闭雨滴效果❗body::after, html::after { display: none !important; }❗*/

  
  /* 5. 侧边距压缩：让正文在手机上能显示更多字 */
  .mes .mes_text { padding: 0 5px !important; font-size: 16px !important; }
}

/* 6. 修复特定 User 横幅图在手机端的裁切问题 */
  /* 将锚点强制钉在右侧（right），垂直方向保持原有的 20% 偏上位置 */
  .mes[is_user="true"]:nth-of-type(3n+2) .avatar img,
  .mes[is_user="true"]:nth-of-type(3n+3) .avatar img {
    object-position: right 20% !important;
  }
}

/* ==================================================== */
/* 底栏菜单终极重构 (保留原生高度 + 极致清晰化) */
/* ==================================================== */

/* 1. 面板底座：只加深背景和模糊，去除了尺寸压缩代码 */
.options-content,
.popup {
    background-color: rgba(12, 18, 28, 0.9) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(98, 159, 255, 0.2) !important;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.7) !important;
    border-radius: 8px !important;
}

/* 2. 菜单项：仅解除系统强制的透明度封印，不碰原生的宽高和边距 */
.options-content .menu_button,
.options-content .list-group-item,
.options-content a, 
.popup .menu_button,
.popup a {
    opacity: 1 !important; 
    background-color: transparent !important;
    display: flex !important;
    align-items: center !important;
    text-decoration: none !important; 
}

/* 3. 分割线修复：保持战术质感 */
.options-content hr, .popup hr {
    border: none !important;
    border-bottom: 1px solid rgba(98, 159, 255, 0.1) !important;
    margin: 6px 0 !important; 
}

/* 4. 悬停交互反馈 */
.options-content .menu_button:hover,
.options-content .list-group-item:hover,
.options-content a:hover,
.popup .menu_button:hover,
.popup a:hover {
    background-color: rgba(98, 159, 255, 0.2) !important;
}

.options-content .menu_button:hover span,
.options-content .list-group-item:hover span,
.options-content a:hover span,
.popup .menu_button:hover span,
.popup a:hover span {
    text-shadow: 0 0 8px rgba(98, 159, 255, 0.8), 0 1px 4px rgba(0,0,0,1) !important;
}

.options-content .menu_button:hover i,
.options-content .list-group-item:hover i,
.options-content a:hover i,
.popup .menu_button:hover i,
.popup a:hover i {
    color: var(--ink-accent) !important;
}
