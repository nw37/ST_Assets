/*
* 主题名称：Nightwing_Dark
* 视觉风格：暗黑哥特基底、夜翼蓝霓虹光效、深色毛玻璃透传、微光排版、纯CSS幽蓝慢雨
* 框架编写/整理：墨千尾 | 二创重构：Vessel | 深色夜翼版适配：Gemini
* 核心逻辑：天地分离交互；Char/User双轨分离；思维链截断；原生模糊释放；文字辉光渲染；轻柔随机慢雨。
*/
/*🦇🏙️🚓🚨🟦🔵💠*/

/* === 先导篇：字体导入 === */
@import url("https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&display=swap");
@font-face {
    font-family: 'ZhuqueFangsong';
    src: url("http://sharkpan.xyz/f/24j6iQ/%E4%B8%AD%E6%96%87%20-%20Huiwen.otf") format('opentype');
    font-weight: normal;
    font-style: normal;
}

/* === 一、全局变量 (深色版重构) === */
:root {
  --font-main: 'ZhuqueFangsong', serif;
  --font-cursive: 'Dancing Script', cursive;

  /* 深色毛玻璃背景变量 */
  --SmartThemeBlurTintColor: rgba(10, 14, 20, 0.7);
  --SmartThemeChatTintColor: rgba(15, 20, 30, 0.75);

/* 主体文字色：从灰蓝调整为冷霜白，在深色背景上提供更利落的轮廓 */
  --ink-main: #DCE4F0;       
  --ink-sub: #4A75B5;        
  --ink-accent: #629FFF; 

  /* 削弱全局发光：去除导致模糊的散光参数，仅保留极微弱的投影以分离背景 */
  --glow-light: 0 1px 1px rgba(0, 0, 0, 0.8);
  --glow-strong: 0 1px 2px rgba(0, 0, 0, 0.9), 0 0 5px rgba(98, 159, 255, 0.3);

  /* 边框与悬停背景 */
  --book-bg-hover: rgba(58, 124, 224, 0.1);
  --book-border: rgba(58, 124, 224, 0.3);

  --mes-user-bg: rgba(98, 159, 255, 0.05);
  --mes-ai-bg: rgba(10, 15, 25, 0.4);

  --cover-title-char: "我会接住你";
  --cover-subtitle-char: "I'll catch you.";
  --author-prefix-char: "-";
  --footer-text-char: "「 每一次跃起，都是通往飞翔的序章 」";

  --avatar-img-user: url('https://images4.alphacoders.com/288/thumb-1920-288238.jpeg');
  --cover-title-user: "飞翔的格雷森";
  --cover-subtitle-user: "Flying Graysons";
  --author-prefix-user: "-";
  --footer-text-user: "「 即使是飞鸟，也终有倦航归巢之时 」";

  --ui-floor-prefix: "跃起 ";
  --ui-floor-suffix: "";
  --ui-time-prefix: "滞空 ";
  --ui-time-suffix: "";
  --ui-token-prefix: "心跳 ";
  --ui-token-suffix: "";

  --input-placeholder: "I've got you.";
  --load-more-text: "· 没入布鲁德海文的夜 ·";
}

