}
.mes:hover .swipe_left,
.mes:hover .swipe_right,
.mes:hover .swipeRightBlock { opacity: 1; }

.mes .swipe_left { left: 2% !important; transform: none !important; }
.mes .swipe_left i { font-size: 0 !important; }
.mes .swipe_left i::before {
  content: '上篇◎' !important;
  font-family: var(--font-main) !important;
  font-size: 13px !important;
  font-style: normal !important;
  letter-spacing: 0.05em;
  color: var(--ink-sub);
  text-shadow: var(--glow-light);
  white-space: nowrap;
  transition: color 0.8s ease, text-shadow 0.8s ease;
}
.mes .swipe_right, .mes .swipeRightBlock { right: 2% !important; transform: none !important; }
.mes .swipe_right i, .mes .swipeRightBlock i { font-size: 0 !important; }
.mes .swipe_right i::before,
.mes .swipeRightBlock i::before {
  content: '◎下篇' !important;
  font-family: var(--font-main) !important;
  font-size: 13px !important;
  font-style: normal !important;
  letter-spacing: 0.05em;
  color: var(--ink-sub);
  text-shadow: var(--glow-light);
  white-space: nowrap;
  transition: color 0.8s ease, text-shadow 0.8s ease;
}

/* 后续 AI 专属翻页微调 */
.mes[is_user="false"] .swipe_left::before,
.mes[is_user="false"] .swipe_left::after,
.mes[is_user="false"] .swipe_right::before,
.mes[is_user="false"] .swipe_right::after { content: none !important; }
.mes[is_user="false"] .swipe_left i,
.mes[is_user="false"] .swipe_right i { font-size: 0 !important; color: transparent !important; }
.mes[is_user="false"] .swipe_left::before {
  content: '上篇◎' !important;
  font-family: var(--font-main) !important;
  font-size: 13px !important;
  color: var(--ink-sub) !important;
  letter-spacing: 0.05em;
  transition: color 0.8s ease;
  white-space: nowrap;
  display: inline-block !important;
  position: relative !important;
  top: -25px !important;
}
.mes[is_user="false"] .swipe_right::before {
  content: '◎下篇' !important;
  font-family: var(--font-main) !important;
  font-size: 13px !important;
  color: var(--ink-sub) !important;
  letter-spacing: 0.05em;
  transition: color 0.8s ease;
  white-space: nowrap;
  display: inline-block !important;
  position: relative !important;
  top: 4px !important;
}
.mes[is_user="false"] .swipe_left:hover::before,
.mes[is_user="false"] .swipe_right:hover::before { color: var(--ink-accent) !important; text-shadow: var(--glow-strong); }

/* 翻页计数器 */
.mes .swipe_info, .mes .swipes_counter {
  position: absolute !important;
  bottom: 5px !important;
  left: 0 !important;
  right: 0 !important;
  margin: 0 auto !important;
  text-align: center !important;
  width: fit-content;
  font-family: var(--font-main) !important;
  font-size: 11px !important;
  color: var(--ink-sub) !important;
  text-shadow: var(--glow-light);
  padding: 0 5px !important;
  z-index: 10;
  opacity: 0.15;
  transition: opacity 0.8s ease;
  pointer-events: auto !important;
}
.mes:hover .swipe_info, .mes:hover .swipes_counter { opacity: 1; }
@media (hover: hover) {
  .mes .swipe_left:hover i::before,
  .mes .swipe_right:hover i::before,
  .mes .swipeRightBlock:hover i::before {
    color: var(--ink-accent) !important;
    text-shadow: var(--glow-strong) !important;
  }
}

/* ==================================================== */
/* 封面文案双轨：动态景深交互 (克制版焦点切换) */
/* ==================================================== */

/* 1. 后景水印 (英文字体) - 常态退居幕后 */
.mes::after {
  position: absolute !important;
  top: 15px !important; 
  left: 0 !important;
  right: 0 !important;
  margin: 0 auto !important;
  text-align: center;
  font-family: var(--font-cursive);
  font-size: 4.5em;
  color: var(--ink-sub);
  text-shadow: var(--glow-light);
  opacity: 0.25; 
  filter: blur(1px); 
  z-index: 1;
  white-space: nowrap;
  pointer-events: none;
  transition: color 0.8s ease, opacity 0.8s ease, text-shadow 0.8s ease, filter 0.8s ease, transform 0.8s ease;
}

/* 2. 后景水印悬停 - 三层物理霓虹渲染 */
.mes:hover:not(:has(.mes_text:hover)):not(:has(.mes_reasoning:hover)):not(:has(.mes_button:hover)):not(:has(.favorite-toggle-icon:hover)):not(:has(.menu_button:hover))::after { 
  color: #DCE8FF !important; 
  text-shadow: 0 0 2px #629FFF, 0 0 8px rgba(98, 159, 255, 0.85), 0 0 18px rgba(20, 80, 180, 0.5) !important; 
  opacity: 0.9 !important; filter: blur(0px) !important; transform: scale(1.02); 
}

.mes[is_user="false"]::after { content: var(--cover-subtitle-char); }
.mes[is_user="true"]::after { content: var(--cover-subtitle-user); }

/* ==================================================== */

/* 3. 前景标题 (中文字体) - 常态绝对清晰 */
.mes::before {
  position: absolute !important;
  top: 65px !important;
  left: 0 !important;
  right: 0 !important;
  margin: 0 auto !important;
  text-align: center;
  font-family: var(--font-main);
  font-size: 1.6em;
  letter-spacing: 0.4em;
  color: var(--ink-accent);
  text-shadow: var(--glow-strong);
  opacity: 1; 
  filter: blur(0px);
  z-index: 2;
  white-space: nowrap;
  pointer-events: none;
  transition: opacity 0.8s ease, filter 0.8s ease, transform 0.8s ease;
}

/* 4. 前景标题悬停 - 失去焦点，但绝不消失 */
/* 【热区修复】：与后景保持同样的排他性触发逻辑 */
.mes:hover:not(:has(.mes_text:hover)):not(:has(.mes_reasoning:hover)):not(:has(.mes_button:hover)):not(:has(.favorite-toggle-icon:hover)):not(:has(.menu_button:hover))::before { 
  opacity: 0.45; filter: blur(1px); transform: scale(0.98); 
}

.mes[is_user="false"]::before { content: var(--cover-title-char); }
.mes[is_user="true"]::before { content: var(--cover-title-user); }

/* 角色名区域重构：去除廉价符号，优化战术冷光质感 */
.mes .ch_name {
  order: 1 !important;
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  margin: 10px auto 15px auto !important;
  padding: 0 !important;
  font-family: var(--font-main);
  font-size: 0.95em !important;
  font-weight: bold !important; /* 稍微加粗，撑起标题分量 */
  color: #B0C4DE !important; /* 冷钢蓝，替代刺眼的纯白 */
  text-shadow: 0 0 8px rgba(176, 196, 222, 0.4); /* 微弱的冷色自发光 */
  letter-spacing: 0.2em; /* 拉开字间距，提升高级感 */
  z-index: 3;
}

/* 彻底封杀原有的破折号 */
.mes .ch_name::before, .mes .ch_name::after {
  content: none !important;
  display: none !important;
}

.mes[is_user="false"] .ch_name::before { content: var(--author-prefix-char); }
.mes[is_user="true"] .ch_name::before { content: var(--author-prefix-user); }

/* 数据行装饰 (黑底更配高级灰蓝) */
.mes .mesIDDisplay i, .mes .mes_timer i, .mes .tokenCounterDisplay i { display: none !important; }
.mes .timestamp { display: none !important; }
/* 1. 基础数据行布局与数值颜色 (冷钢灰，不透明) */
.mes .mesIDDisplay, .mes .mes_timer, .mes .tokenCounterDisplay {
  display: block !important;
  width: 100%;
  text-align: center;
  font-family: var(--font-main);
  font-size: 0.75em !important;
  color: #8BA8CC !important;          
  text-shadow: none !important; 
  margin: 3px 0 !important;
  letter-spacing: 0.1em;
  opacity: 1 !important; 
  z-index: 3;
}

/* 2. 元素排序与底部分隔线 (保留原有结构) */
.mes .mesIDDisplay { order: 2 !important; }
.mes .mes_timer { order: 3 !important; }
.mes .tokenCounterDisplay {
  order: 4 !important;
  margin-bottom: 25px !important;
  border-bottom: 1px solid var(--book-border);
  padding-bottom: 25px !important;
}

/* 3. 前缀/后缀的文本调用与独立颜色 (夜翼蓝) */
.mes .mesIDDisplay::before { content: var(--ui-floor-prefix); margin-right: 6px; color: var(--ink-sub) !important; }
.mes .mesIDDisplay::after { content: var(--ui-floor-suffix); margin-left: 4px; color: var(--ink-sub) !important; }

.mes .mes_timer::before { content: var(--ui-time-prefix); margin-right: 6px; color: var(--ink-sub) !important; }
.mes .mes_timer::after { content: var(--ui-time-suffix); margin-left: 4px; color: var(--ink-sub) !important; }

.mes .tokenCounterDisplay::before { content: var(--ui-token-prefix); margin-right: 6px; color: var(--ink-sub) !important; }
.mes .tokenCounterDisplay::after { content: var(--ui-token-suffix); margin-left: 4px; color: var(--ink-sub) !important; }

/* 思维链容器 */
.mes[is_user="false"] details:has(.mes_reasoning_summary),
.mes[is_user="false"] .mes_block details {
  order: 5 !important;
  width: 85% !important;
  margin: 0 auto 8px auto !important;
  z-index: 3;
  display: block !important;
}

/* 正文宽屏 */
.mes .mes_text {
  order: 7 !important;
  line-height: 1.95 !important;
  color: var(--ink-main);
  font-size: 19px !important;
  width: 100% !important;
  padding: 0 15px !important;
  margin: 0 auto !important;
  text-align: justify;
  z-index: 3;
}
.mes_text p { margin-bottom: 1.2em !important; }
.mes_text i, .mes_text em {
  font-style: normal !important;
  color: var(--ink-accent); /* 深底上用亮色提亮斜体 */
  text-shadow: 0 0 5px rgba(98, 159, 255, 0.4);
}
.mes_text blockquote {
  margin: 1.5em 0 !important;
  padding: 10px 15px !important;
  background-color: var(--book-bg-hover);
  border-left: 3px solid var(--ink-accent);
  color: var(--ink-main);
  font-size: 0.95em;
  border-radius: 0;
}
.mes_text b, .mes_text strong {
  font-weight: normal;
  color: var(--ink-accent);
  border-bottom: 1px solid var(--book-border);
}

/* 避免最后一条消息留白 */
.mes.last_mes { margin-bottom: 0px !important; }
.mes.last_mes .mesAvatarWrapper { padding-bottom: 0px !important; }

/* 顶栏+底栏与聊天界面缝隙修正 */
#form_sheld { margin: 0 auto !important; }
body:not(.waifuMode) #sheld {
  top: var(--bottomFormBlockSize);
  height: calc(100dvh - var(--bottomFormBlockSize));
  min-height: calc(100dvh - var(--bottomFormBlockSize));
}

/* ===== 五、滚动条与滑块 ===== */
::-webkit-scrollbar { width: 6px; height: 6px; background-color: transparent; }
::-webkit-scrollbar-track { background-color: transparent; }
::-webkit-scrollbar-thumb {
  background-color: rgba(98, 159, 255, 0.3);
  border-radius: 10px;
  border: none;
  box-shadow: 0 0 5px rgba(98, 159, 255, 0.2) !important;
}
::-webkit-scrollbar-thumb:hover { background-color: var(--ink-sub); }

input[type="range"] {
  -webkit-appearance: none;
  appearance: none;
  background: transparent !important;
  cursor: pointer;
}
input[type="range"]::-webkit-slider-runnable-track {
  width: 100%; height: 2px; background: var(--book-border); border-radius: 0px; border: none;
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none; appearance: none;
  margin-top: -6px; height: 14px; width: 6px;
  background-color: var(--ink-main); border: none; border-radius: 0;
  box-shadow: 0 0 8px rgba(98, 159, 255, 0.5);
  transition: transform 0.8s ease;
}
input[type="range"]:hover::-webkit-slider-thumb,
input[type="range"]:active::-webkit-slider-thumb {
  transform: scale(1.2); background-color: var(--ink-accent);
}
input[type="range"]::-moz-range-track {
  height: 2px; background: var(--book-border); border-radius: 0px; border: none;
}
input[type="range"]::-moz-range-thumb {
  height: 14px; width: 6px; background-color: var(--ink-main);
  border: none; border-radius: 0; box-shadow: 0 0 8px rgba(98, 159, 255, 0.5);
}

/* ===== 六、输入框占位符 ===== */
#nonQRFormItems { position: relative; }
#send_textarea::placeholder { color: transparent !important; text-shadow: none !important; }
#nonQRFormItems:has(#send_textarea:placeholder-shown)::before {
  color: var(--ink-sub);
  content: var(--input-placeholder);
  text-shadow: var(--glow-light);
  position: absolute;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--font-main);
  font-size: 0.75em;
  line-height: 1.5;
  pointer-events: none;
  z-index: 10;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
  max-width: calc(100% - 30px);
}

/* ===== 七、正则脚本防误触 (深色适配) ===== */
#saved_regex_scripts,
#saved_scoped_scripts,
#saved_preset_scripts,
#global-script-list,
#character-script-list {
  margin-right: 80px !important;
}
.regex-script-label.flex-container,
.flex-container .script-item {
  flex-wrap: wrap !important;
  padding: 5px 10px;
  border-radius: 4px;
  margin-bottom: 5px;
  background: rgba(20, 25, 35, 0.6);
  border: 1px solid var(--book-border);
}
.regex-script-label.flex-container .regex_script_name,
.script-item .script-item-name {
  flex-basis: 100%;
  white-space: normal;
  overflow: visible;
  text-overflow: clip;
  word-break: break-word;
  font-weight: normal;
  font-size: 1.05em;
  color: var(--ink-main);
  text-shadow: var(--glow-light);
}
.regex-script-label.flex-container > .flex-container.flexnowrap,
.script-item .script-item-control {
  width: 100%;
  justify-content: flex-start;
}

/* ===== 八、加载更多 ===== */
#show_more_messages {
  font-size: 0 !important;
  color: transparent !important;
  display: block;
  padding: 8px 30px;
  margin: 30px auto;
  width: fit-content;
  background-color: transparent;
  border: 1px solid var(--book-border);
  border-radius: 50px;
  box-shadow: none;
  cursor: pointer;
  transition: all 0.8s ease;
}
#show_more_messages::before {
  content: var(--load-more-text);
  font-family: var(--font-main);
  font-size: 13px !important;
  color: var(--ink-sub) !important;
  letter-spacing: 0.2em;
  text-shadow: var(--glow-light);
  transition: color 0.8s ease, text-shadow 0.8s ease;
}
@media (hover: hover) {
  #show_more_messages:hover {
    background-color: var(--book-bg-hover);
    border-color: var(--ink-accent);
    box-shadow: 0 0 15px rgba(98, 159, 255, 0.2);
  }
  #show_more_messages:hover::before {
    color: var(--ink-accent) !important;
    text-shadow: var(--glow-strong);
  }
}

/* ===== 九、思维链美化 (深黑玻璃风) ===== */
@keyframes poetic-breathing {
  0% {
    opacity: var(--breath-min);
    filter: blur(1px);
    text-shadow: var(--glow-light);
  }
  50% {
    opacity: 1;
    filter: blur(0px);
    text-shadow: var(--glow-strong);
  }
  100% {
    opacity: var(--breath-min);
    filter: blur(1px);
    text-shadow: var(--glow-light);
  }
}
.mes[is_user="false"] details:has(.mes_reasoning:empty) { display: none !important; }
.mes[is_user="false"] .mes_reasoning_header_title:empty::before {
  content: none !important; display: none !important;
}

.mes[is_user="false"] .mes_reasoning_header {
  background: transparent !important;
  border: none !important;
  border-radius: 0;
  padding: 5px 0;
  transition: all 0.8s ease-in-out;
  text-align: center;
  width: 100% !important;
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}
.mes[is_user="false"] .mes_reasoning_header_title {
  font-size: 0 !important;
  display: block !important;
  width: 100% !important;
  text-align: center !important;
}
.mes[is_user="false"] .mes_reasoning_header_title::before {
  content: var(--reasoning-text);
  font-family: var(--font-main);
  font-size: 0.85rem !important;
  color: var(--ink-accent);
  font-weight: normal;
  letter-spacing: 0.1em;
  white-space: pre-wrap;
  line-height: 1.8;
  display: block !important;
  width: 100% !important;
  text-align: center !important;
  transition: opacity 0.8s ease, filter 0.8s ease, text-shadow 0.8s ease !important;
  animation: poetic-breathing 8s ease-in-out infinite;
}
.mes[is_user="false"] .mes_reasoning_summary {
  list-style: none;
  cursor: pointer;
  display: flex !important;
  justify-content: center !important;
  align-items: center;
  width: 100%;
  margin: 0 !important;
}
.mes[is_user="false"] .mes_reasoning_summary::-webkit-details-marker { display: none !important; }
.mes[is_user="false"] .mes_reasoning_arrow { display: none !important; }

.mes[is_user="false"] .mes_reasoning {
  margin: 10px auto 25px auto !important;
  padding: 20px 30px !important;
  background-color: rgba(20, 30, 45, 0.6) !important; /* 调整为深色深邃蓝黑框 */
  backdrop-filter: blur(8px);
  border: 1px solid var(--book-border) !important;
  border-left: 3px double var(--ink-sub) !important; /* 加强左侧边界 */
  border-radius: 2px 6px 6px 2px !important;
  color: var(--ink-main) !important;
  font-family: var(--font-main) !important;
  font-size: 0.95em !important;
  line-height: 1.8 !important;
  text-align: justify !important;
  text-shadow: none !important;
  box-shadow: inset 0 0 20px rgba(98, 159, 255, 0.05) !important;
  width: 100%;
  max-height: 60vh !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
}
.mes[is_user="false"] .mes_reasoning::-webkit-scrollbar { width: 4px !important; }
.mes[is_user="false"] .mes_reasoning::-webkit-scrollbar-track { background: transparent !important; }
.mes[is_user="false"] .mes_reasoning::-webkit-scrollbar-thumb {
  background: var(--book-border) !important;
  border-radius: 10px !important;
}
.mes[is_user="false"] .mes_reasoning::-webkit-scrollbar-thumb:hover { background: var(--ink-accent) !important; }

/* 悬停时定格呼吸动画，诗句完全清晰 */
.mes[is_user="false"] .mes_reasoning_header:hover .mes_reasoning_header_title::before {
  /* 悬停时不要暂停动画，直接用 !important 强杀当前帧的属性 */
  opacity: 1 !important;
  filter: blur(0px) !important;
  text-shadow: var(--glow-strong) !important;
  /* 配合 transition，移入时会平滑亮起；移出时虽然依然会交还给动画，但高延迟的 transition 会在一定程度上缓冲掉断崖式的跳变感 */
}

/* ===== 十、收藏栏滑动 ===== */
.hotswap.avatars_inline {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  padding-right: 15px;
}
.hotswap.avatars_inline::-webkit-scrollbar { display: none; }
.hotswap.avatars_inline { scrollbar-width: none; }
@media (max-width: 768px) {
  .hotswap.avatars_inline { overflow: auto; flex-wrap: wrap; }
}

/* ===== 十一、隐形寄语双轨 (修复隐形与模糊问题) ===== */
.mes_text::after {
  display: block;
  width: 100%;
  margin: 30px auto 0 auto;
  text-align: center;
  color: var(--ink-sub);
  font-family: var(--font-main);
  font-size: 13px;
  letter-spacing: 0.4em;
  text-shadow: none !important; /* 移除常态阴影 */
  /* 提高透明度，保证无需鼠标移上去也能阅读 */
  opacity: 0.4; 
  /* 彻底移除 blur 滤镜，保证文字边缘清晰 */
  filter: blur(0px); 
  transition: opacity 1.5s ease, text-shadow 1.5s ease, color 1.5s ease;
}
.mes:hover .mes_text::after {
  opacity: 0.9;
  color: var(--ink-accent);
  text-shadow: var(--glow-light); /* 仅在悬停时增加微弱的辉光 */
}
.mes[is_user="false"] .mes_text::after { content: var(--footer-text-char); }
.mes[is_user="true"] .mes_text::after { content: var(--footer-text-user); }

/* ===== 十二、提示词头部修复 ===== */
.completion_prompt_manager_header {
  color: var(--ink-sub) !important;
}

/* ===== 提示词管理器毛玻璃 (深色适配) ===== */
#completion_prompt_manager_list,
.ui-sortable {
  background-color: rgba(15, 20, 25, 0.6) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  color: var(--ink-main) !important;
  border-radius: 8px;
}
#completion_prompt_manager_list .ui-sortable > li,
#completion_prompt_manager_list .list-group-item {
  background: rgba(30, 40, 55, 0.4) !important;
  border: .5px solid var(--book-border) !important;
  color: var(--ink-main) !important;
  margin: 2px 0;
}
#completion_prompt_manager_list .ui-sortable > li:hover,
#completion_prompt_manager_list .list-group-item:hover {
  background: rgba(45, 65, 90, 0.6) !important;
}

/* ===== 底部 QR 栏 (深黑半透明) ===== */
#qr--bar {
  position: absolute !important;
  bottom: 100% !important;
  left: 0;
  width: 100%;
  z-index: 999;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  margin-bottom: 0;
  pointer-events: none;
  transition: all 0.3s ease 0.6s;
  background: rgba(15, 20, 28, 0.85) !important;
  backdrop-filter: blur(40px) !important;
  -webkit-backdrop-filter: blur(40px) !important;
  border: 1px solid var(--book-border);
  border-bottom: none;
  border-radius: 8px 8px 0 0;
  box-shadow: 0 -8px 20px rgba(0, 0, 0, 0.3);
}
#send_form:hover #qr--bar,
#qr--bar:hover {
  max-height: 500px;
  opacity: 1;
  margin-bottom: 2px;
  pointer-events: auto;
  transition: all 0.3s ease 0s;
}
#qr--bar > div {
  display: flex !important;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4px !important;
  padding: 6px !important;
}
#qr--bar .qr-link,
#qr--bar .qr--button {
  padding: 4px 10px !important;
  font-size: 13px !important;
  margin: 0 !important;
  background: rgba(30, 45, 65, 0.6) !important;
  border: 1px solid var(--book-border) !important;
  border-radius: 4px;
  color: var(--ink-main) !important;
}
#qr--bar .qr-link:hover,
#qr--bar .qr--button:hover {
  background: var(--ink-sub) !important;
  color: #fff !important;
  box-shadow: var(--glow-light);
}

/* ===== 选中文本荧光笔 (方案B：终端反相高亮) ===== */
.mes_text ::selection {
  background: #629FFF !important; /* 背景使用极亮的高饱和夜翼蓝 */
  color: #0A0F1A !important;      /* 文字反相为极深邃的暗夜黑 */
  text-shadow: none !important;   /* 必须移除阴影 */
}

/* ===== 对白高亮 (夜翼战术HUD版) ===== */
.mes_text q, .mes_text b, .mes_text strong {
  font-style: normal !important;
  quotes: none !important;
  font-weight: normal;
  text-shadow: none !important; 
  
  /* 对白文字颜色：经典的夜翼战衣蓝 */
  color: #5B9DFF !important; 
  
  /* 对白底色：极度深邃的暗夜蓝，确保高亮蓝色文字的绝对辨识度 */
  background-color: rgba(12, 22, 38, 0.7) !important;
  
  /* 增加战术边框：极细微的蓝色轮廓线，强化面板质感 */
  border: 1px solid rgba(91, 157, 255, 0.1) !important;
  
  margin: 0px 3px !important;
  padding: 2px 6px !important;
  border-radius: 4px !important;
  font-size: 1em !important;
  display: inline;
  box-decoration-break: clone;
  -webkit-box-decoration-break: clone;
}

/* ===== 全局输入框/选择框背景统一修复 (深色暗化) ===== */
textarea,
select,
